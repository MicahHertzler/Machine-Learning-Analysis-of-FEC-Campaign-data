# 3.  FEATURE ENGINEERING
# ══════════════════════════════════════════════════════════════════════════════

def engineer_features(df: pd.DataFrame) -> pd.DataFrame:
    """Add all model features in-place."""

    def prev_win(text):
        t = str(text).lower()
        return 1 if t[:3] == "won" else (0 if t[:4] == "lost" else -1)

    df["prev_win"]    = df["candidate_previous_election_results_based_on_given_year"].apply(prev_win)
    df["is_dem"]      = (df["party_clean"] == "Democratic").astype(int)
    df["is_female"]   = (df["gender"].str.lower().str.strip() == "female").astype(int)
    df["has_religion"]= df["stated_religion_if_found"].notna().astype(int)
    df["is_white"]    = (df["race_ethnicity_if_found"].fillna("")
                           .str.lower().str.contains("white|caucasian")).astype(int)
    df["is_nonwhite"] = (df["race_ethnicity_if_found"].notna() &
                         ~df["race_ethnicity_if_found"].fillna("")
                          .str.lower().str.contains("white|caucasian")).astype(int)
    df["age"]         = df["age_clean"].fillna(df["age_clean"].median())

    # financial — use whichever column name is present
    def get_col(d, *names):
        for n in names:
            if n in d.columns:
                return d[n].fillna(0)
        return pd.Series(0, index=d.index)

    df["spending"]     = get_col(df, "campaign_spending_2023_2024")
    df["disbursement"] = get_col(df, "Total_Disbursement", "weball24_disbursements")
    df["receipts"]     = get_col(df, "total_receipts_weball24", "weball24_receipts")
    df["ie_net"]       = (get_col(df, "weball24_ie_supporting") -
                          get_col(df, "weball24_ie_opposing"))
    df["cash_end"]     = get_col(df, "weball24_cash_on_hand_end")
    df["debt"]         = get_col(df, "weball24_debts_owed_by")

    # district features (only rows with PVI)
    pvi_mask = df["district_pvi"].notna()
    df.loc[pvi_mask, "district_safety"] = df.loc[pvi_mask, "district_pvi"].abs()
    df.loc[pvi_mask, "party_district_align"] = df.loc[pvi_mask].apply(
        lambda r: r["district_pvi"] if r["is_dem"] == 1 else -r["district_pvi"], axis=1)
    df.loc[pvi_mask, "is_underdog"] = (
        ((df.loc[pvi_mask, "is_dem"] == 1) & (df.loc[pvi_mask, "district_pvi"] < 0)) |
        ((df.loc[pvi_mask, "is_dem"] == 0) & (df.loc[pvi_mask, "district_pvi"] > 0))
    ).astype(int)

    return df


