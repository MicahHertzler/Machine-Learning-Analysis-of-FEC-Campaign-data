        rows.append({"n_train": int(n), "train_auc": round(tr, 3),
                     "val_auc": round(vl, 3)})
    pd.DataFrame(rows).to_csv("output/learning_curve_rf.csv", index=False)


def section_religion(df):
    """Religion classification and win rates."""

    def classify(val):
        if pd.isna(val) or str(val).strip() in ("", "nan", "None", "unknown"):
            return "Unknown"
        v = str(val).lower()
        for kw in ["catholic", "protestant", "baptist", "methodist", "evangelical",
                   "lutheran", "presbyterian", "episcopal", "mormon", "lds",
                   "christian", "pentecostal", "reformed", "anglican", "adventist",
                   "church of christ", "nondenominational", "born again"]:
            if kw in v:
                return "Christian"
        for kw in ["jewish", "judaism"]:
            if kw in v:
                return "Jewish"
        for kw in ["muslim", "islam"]:
            if kw in v:
                return "Muslim"
        for kw in ["hindu"]:
            if kw in v:
                return "Hindu"
        return "Other"

    df["religion_cat"] = df["stated_religion_if_found"].apply(classify)
    y = (df["target_raw"] == "Won").astype(int)

    print(f"\n{'─'*60}")
    print("  RELIGION ANALYSIS")
    print(f"{'─'*60}")
    grp = df.groupby("religion_cat")["target_raw"].value_counts(
        normalize=True).unstack().fillna(0)
    grp["n"] = df["religion_cat"].value_counts()
    print(grp.sort_values("Won", ascending=False).round(3).to_string())

    valid = df["religion_cat"].value_counts()
    valid = valid[valid >= 5].index
    df_v  = df[df["religion_cat"].isin(valid)]
    if len(valid) >= 2:
        ct = pd.crosstab(df_v["religion_cat"], df_v["target_raw"])
        chi2, p, dof, _ = stats.chi2_contingency(ct)
        print(f"\n  Chi-square: chi2={chi2:.3f}  p={p:.4f}  dof={dof}")

    df[["religion_cat", "target_raw"]].to_csv(
        "output/S3_religion_breakdown.csv", index=False)


