# 4.  SHARED CONSTANTS
# ══════════════════════════════════════════════════════════════════════════════

FEATURES_FINANCIAL = ["spending", "disbursement", "receipts", "ie_net",
                       "cash_end", "debt", "prev_win"]

FEATURES_DEMO      = ["is_dem", "is_female", "age", "is_white",
                       "is_nonwhite", "has_religion"]

FEATURES_DISTRICT  = ["district_pvi", "party_district_align",
                       "district_safety", "is_underdog"]

FEATURES_ALL       = FEATURES_FINANCIAL + FEATURES_DEMO + FEATURES_DISTRICT

FEATURES_NO_PARTY  = [f for f in FEATURES_ALL if f != "is_dem"]

CV = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)


def make_models():
    return {
        "Logistic Regression": LogisticRegression(
            class_weight="balanced", max_iter=1000, C=0.5),
        "Random Forest": RandomForestClassifier(
            n_estimators=300, random_state=42, class_weight="balanced"),
        "Gradient Boosting": GradientBoostingClassifier(
            n_estimators=200, max_depth=3, random_state=42),
    }


def evaluate_models(X, y, label=""):
    """Run 5-fold CV for all three models. Returns results dict."""
    scaler = StandardScaler()
    Xs = scaler.fit_transform(X)
    results = {}
    print(f"\n{'─'*60}")
    print(f"  {label}  (n={len(y)}, won={y.sum()}, lost={(y==0).sum()})")
    print(f"{'─'*60}")
    print(f"  {'Model':<25} {'AUC':>7} {'Acc':>7} {'F1':>7}")
    for name, model in make_models().items():
        auc = cross_val_score(model, Xs, y, cv=CV, scoring="roc_auc").mean()
        acc = cross_val_score(model, Xs, y, cv=CV, scoring="accuracy").mean()
        f1  = cross_val_score(model, Xs, y, cv=CV, scoring="f1").mean()
        results[name] = {"auc": auc, "acc": acc, "f1": f1}
        print(f"  {name:<25} {auc:>7.3f} {acc:>7.3f} {f1:>7.3f}")
    return results, scaler


def rf_importances(X, y, feature_names, scaler):
    """Fit RF on full dataset, return importance Series."""
    Xs = scaler.transform(X)
    rf = RandomForestClassifier(n_estimators=300, random_state=42,
                                 class_weight="balanced")
    rf.fit(Xs, y)
    return pd.Series(rf.feature_importances_, index=feature_names).sort_values(ascending=False)


def lr_coefficients(X, y, feature_names, scaler):
    """Fit LR on full dataset, return coefficient Series."""
    Xs = scaler.transform(X)
    lr = LogisticRegression(class_weight="balanced", max_iter=1000, C=0.5)
    lr.fit(Xs, y)
    return pd.Series(lr.coef_[0], index=feature_names).sort_values(key=abs, ascending=False)


