# 5.  SECTION RUNNERS
# ══════════════════════════════════════════════════════════════════════════════

def section_all_districts(df):
    """Models on all PVI-mapped D+R candidates."""
    d = df[df["district_pvi"].notna()].copy()
    y = (d["target_raw"] == "Won").astype(int)
    feats = [f for f in FEATURES_ALL if f in d.columns]
    X = d[feats].fillna(0)

    results, scaler = evaluate_models(X, y, "ALL PVI-MAPPED DISTRICTS")

    print("\n  RF Feature Importances — All Districts:")
    imps = rf_importances(X, y, feats, scaler)
    for feat, imp in imps.items():
        bar = "█" * int(imp * 80)
        print(f"    {feat:<28} {imp:.4f}  {bar}")

    print("\n  LR Coefficients — All Districts:")
    coefs = lr_coefficients(X, y, feats, scaler)
    for feat, c in coefs.items():
        print(f"    {feat:<28} {c:+.4f}  {'↑WIN' if c > 0 else '↓LOSE'}")

    imps.to_csv("output/S1_rf_importances_all_districts.csv")
    print("\n  → Supplemental Table S1 saved: output/S1_rf_importances_all_districts.csv")
    return results


def section_demographic_isolation(df):
    """Three demographic isolation methods."""
    d = df[df["district_pvi"].notna()].copy()
    y = (d["target_raw"] == "Won").astype(int)
    scaler = StandardScaler()

    demo_feats = ["is_dem", "is_female", "age", "is_white",
                  "is_nonwhite", "has_religion"]
    conf_feats = [f for f in FEATURES_FINANCIAL + FEATURES_DISTRICT
                  if f in d.columns]
    all_feats  = [f for f in FEATURES_ALL if f in d.columns]

    print(f"\n{'─'*60}")
    print("  DEMOGRAPHIC ISOLATION METHODS")
    print(f"{'─'*60}")

    # Method 1 — demographics only
    X1 = scaler.fit_transform(d[demo_feats].fillna(0))
    lr1 = LogisticRegression(class_weight="balanced", max_iter=1000, C=0.1)
    auc1 = cross_val_score(lr1, X1, y, cv=CV, scoring="roc_auc").mean()
    print(f"\n  Method 1 — Demographics only          AUC = {auc1:.3f}")
    lr1.fit(X1, y)
    for f, c in sorted(zip(demo_feats, lr1.coef_[0]),
                       key=lambda x: abs(x[1]), reverse=True):
        print(f"    {f:<20} {c:+.4f}  {'↑WIN' if c > 0 else '↓LOSE'}")

    # Method 2 — residualised
    X_conf = scaler.fit_transform(d[conf_feats].fillna(0))
    residuals = {}
    for feat in demo_feats:
        vals = d[feat].fillna(0).values.astype(float)
        lr_r = LinearRegression().fit(X_conf, vals)
        residuals[feat] = vals - lr_r.predict(X_conf)
    X2 = scaler.fit_transform(pd.DataFrame(residuals))
    lr2 = LogisticRegression(class_weight="balanced", max_iter=1000, C=0.1)
    auc2 = cross_val_score(lr2, X2, y, cv=CV, scoring="roc_auc").mean()
    print(f"\n  Method 2 — Residualised demographics  AUC = {auc2:.3f}")

    # Method 3 — full model delta
    X_money = scaler.fit_transform(d[conf_feats].fillna(0))
    X_full  = scaler.fit_transform(d[all_feats].fillna(0))
    lr_m = LogisticRegression(class_weight="balanced", max_iter=1000, C=0.1)
    lr_f = LogisticRegression(class_weight="balanced", max_iter=1000, C=0.1)
    auc_m = cross_val_score(lr_m, X_money, y, cv=CV, scoring="roc_auc").mean()
    auc_f = cross_val_score(lr_f, X_full,  y, cv=CV, scoring="roc_auc").mean()
    print(f"\n  Method 3 — AUC delta")
    print(f"    Financial only:         {auc_m:.3f}")
    print(f"    Financial + demo:       {auc_f:.3f}")
    print(f"    Demographic added value: +{auc_f - auc_m:.3f}")


