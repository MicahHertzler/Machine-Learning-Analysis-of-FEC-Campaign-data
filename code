            print(f"    {label:<12} YES={g.loc[1,'Won']:.1%}  NO={g.loc[0,'Won']:.1%}")


def section_age_analysis(df):
    """Age — linear, decade bins, 5-year bins, party breakdown."""
    d = df[(df["district_pvi"].notna()) &
           (df["district_pvi"].abs() <= 7) &
           (df["age_clean"].notna())].copy()
    y = (d["target_raw"] == "Won").astype(int)

    print(f"\n{'─'*60}")
    print(f"  AGE ANALYSIS — Swing districts with valid age  n={len(d)}")
    print(f"{'─'*60}")

    # ── linear ──────────────────────────────────────────────────────────────
    r_lin, p_lin = stats.pointbiserialr(y, d["age_clean"])
    print(f"\n  Linear age correlation: r={r_lin:+.3f}  p={p_lin:.3f}")

    # ── decade bins ─────────────────────────────────────────────────────────
    d["decade"] = (d["age_clean"] // 10 * 10).astype(int)
    dec_stats = d.groupby("decade").agg(
        n=("target_raw", "count"),
        won=("target_raw", lambda x: (x == "Won").sum())
    ).reset_index()
    dec_stats["win_rate"] = (dec_stats["won"] / dec_stats["n"] * 100).round(1)
    print("\n  Decade win rates:")
    print(dec_stats.to_string(index=False))
    ct_dec = pd.crosstab(d["decade"], d["target_raw"])
    chi2_d, p_d, dof_d, _ = stats.chi2_contingency(ct_dec)
    print(f"  Chi-square (decades): chi2={chi2_d:.3f}  p={p_d:.4f}  dof={dof_d}")

    # ── party within decade ──────────────────────────────────────────────────
    print("\n  Party × decade win rates:")
    print(d.groupby(["decade", "party_clean"])["target_raw"]
           .value_counts(normalize=True).unstack().fillna(0).round(3))

    # ── 5-year bins ──────────────────────────────────────────────────────────
    bins5   = list(range(25, 86, 5))
    labels5 = [f"{b}-{b+4}" for b in bins5[:-1]]
    d["age_5yr"] = pd.cut(d["age_clean"], bins=bins5, labels=labels5, right=False)
    s5 = d.groupby("age_5yr", observed=True).agg(
        n=("target_raw", "count"),
        won=("target_raw", lambda x: (x == "Won").sum())
    ).reset_index()
    s5["win_rate"] = (s5["won"] / s5["n"] * 100).round(1)
    s5["status"]   = s5.apply(
        lambda r: "SOLID" if r["n"] >= 10 and r["won"] >= 2 and (r["n"] - r["won"]) >= 2
                  else "usable" if r["n"] >= 5 and r["won"] >= 1 and (r["n"] - r["won"]) >= 1
                  else "too small", axis=1)
    print("\n  5-year bin win rates:")
    for _, r in s5[s5["n"] > 0].iterrows():
        print(f"    {str(r['age_5yr']):<10} n={int(r['n']):>3}  won={int(r['won']):>3}"
              f"  {r['win_rate']:>5}%  {r['status']}")

    viable = s5[(s5["n"] >= 5) & (s5["won"] >= 1) & ((s5["n"] - s5["won"]) >= 1)]
    if len(viable) >= 3:
        df_v  = d[d["age_5yr"].isin(viable["age_5yr"].values)]
        ct5   = pd.crosstab(df_v["age_5yr"], df_v["target_raw"])
        chi2_5, p_5, dof_5, _ = stats.chi2_contingency(ct5)
        print(f"  Chi-square (5-yr bins): chi2={chi2_5:.3f}  p={p_5:.4f}  dof={dof_5}")

    s5.to_csv("output/S2_age_5yr_bins.csv", index=False)
    print("  → Supplemental Figure S2 data saved: output/S2_age_5yr_bins.csv")


def section_power_analysis():
    """Statistical power — rows needed for each demographic signal."""

    def power_for_r(r, n, alpha=0.05):
        if abs(r) < 0.001 or n < 4:
            return 0.0
        zr  = np.arctanh(abs(r))
        za  = norm.ppf(1 - alpha / 2)
        ncp = zr * np.sqrt(n - 3)
        return 1 - norm.cdf(za - ncp) + norm.cdf(-za - ncp)

    def n_for_power(r, power=0.80, alpha=0.05):
        if abs(r) < 0.001:
            return float("inf")
        zr   = np.arctanh(abs(r))
        za   = norm.ppf(1 - alpha / 2)
        zbeta = norm.ppf(power)
        return int(np.ceil(((za + zbeta) / zr) ** 2 + 3))

    signals = [
        ("gender (is_female)",  -0.213, 88),
        ("race (is_white)",     +0.208, 88),
        ("district-race match", +0.108, 77),
        ("age (linear)",        +0.047, 88),
    ]

    print(f"\n{'─'*60}")
    print("  POWER ANALYSIS — rows needed per signal (swing districts)")
    print(f"{'─'*60}")
    print(f"  {'Signal':<25} {'r':>6} {'N now':>7} {'Power now':>10} "
          f"{'N@80%':>8} {'N@90%':>8}")

    rows = []
    for label, r, n_now in signals:
        pwr_now = power_for_r(r, n_now)
        n80     = n_for_power(r, 0.80)
        n90     = n_for_power(r, 0.90)
        print(f"  {label:<25} {r:>+6.3f} {n_now:>7} {pwr_now:>9.1%} "
              f"{n80:>8} {n90:>8}")
        rows.append({"signal": label, "r": r, "n_current": n_now,
                     "power_current": round(pwr_now, 3),
                     "n_needed_80pct": n80, "n_needed_90pct": n90})

    pd.DataFrame(rows).to_csv("output/S3_power_analysis.csv", index=False)
    print("  → Supplemental Table S3 saved: output/S3_power_analysis.csv")


