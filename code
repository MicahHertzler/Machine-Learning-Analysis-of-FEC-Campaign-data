# 2.  DATA LOADING & CLEANING
# ══════════════════════════════════════════════════════════════════════════════

def load_and_clean(csv_path: str) -> pd.DataFrame:
    """Load FEC CSV, standardise columns, return clean DataFrame."""
    df = pd.read_csv(csv_path)

    # ── party ───────────────────────────────────────────────────────────────
    party_map = {
        "REP": "Republican", "DEM": "Democratic", "Democrat": "Democratic",
        "Republican": "Republican", "Democratic": "Democratic", "DFL": "Democratic",
    }
    df["party_clean"] = df["political_party"].map(party_map).fillna("Other")

    # ── age ─────────────────────────────────────────────────────────────────
    df["age_clean"] = pd.to_numeric(df["age_at_given_year"], errors="coerce")
    df["age_clean"] = df["age_clean"].where(df["age_clean"].between(22, 85))

    # ── target ──────────────────────────────────────────────────────────────
    df["target_raw"] = df["won_or_lost_house_race_for_given_year"].str.strip()
    df.loc[df["target_raw"].str.contains("Won special election", na=False), "target_raw"] = "Won"

    # ── filter ──────────────────────────────────────────────────────────────
    df = df[df["target_raw"].isin(["Won", "Lost"])].copy()
    df = df[df["party_clean"].isin(["Democratic", "Republican"])].copy()

    # ── PVI ─────────────────────────────────────────────────────────────────
    df["district_pvi"] = df["location"].map(PVI_MAP)

    # ── financial ───────────────────────────────────────────────────────────
    for col in ["campaign_spending_2023_2024", "Total_Disbursement",
                "total_receipts_weball24", "weball24_ie_supporting",
                "weball24_ie_opposing", "weball24_cash_on_hand_end",
                "weball24_debts_owed_by"]:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce").fillna(0)

    print(f"[load] rows={len(df)}  "
          f"Won={( df['target_raw']=='Won').sum()}  "
          f"Lost={(df['target_raw']=='Lost').sum()}  "
          f"PVI-mapped={(df['district_pvi'].notna()).sum()}")
    return df


